# ----- Preview mode -----
# 1 = run locally with NO accounts (in-process DB, login bypassed, sample data).
# Leave unset/0 for the real app with the keys below.
PREVIEW_MODE="0"

# ----- Database (Neon - free Postgres) -----
# Create a project at https://neon.tech (or via Vercel Marketplace) and paste the pooled connection string.
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# ----- Auth (Clerk - free) -----
# Create an app at https://clerk.com (or via Vercel Marketplace). Enable the sign-in methods you want (e.g. Email, Facebook).
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_xxx"
CLERK_SECRET_KEY="sk_test_xxx"
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL="/today"
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL="/today"

# ----- Branding (keeps the public repo generic — set your own) -----
NEXT_PUBLIC_APP_NAME="Prayer Helper"
# Your community/group name (shown on cards + footer). Leave blank to hide.
NEXT_PUBLIC_GROUP_NAME=""
NEXT_PUBLIC_APP_TAGLINE="A private space to pray for our kids — by name, every day."

# ----- App config -----
# Comma-separated emails that are automatically admins on first login.
ADMIN_EMAILS="you@example.com"
# Timezone used to decide "today" for the daily prayer rotation.
APP_TIMEZONE="America/New_York"
# Number of kids featured each day.
DAILY_COUNT="9"
# Secret required to trigger the daily generation cron. You must set this yourself
# (in Vercel too) — Vercel sends it with cron requests but does NOT create it.
# The cron endpoint refuses all requests until it's set.
CRON_SECRET="change-me-to-a-long-random-string"

# ----- Photo uploads (Vercel Blob - free) -----
# Auto-added by the Vercel Blob integration. Needed for profile photo uploads.
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_xxx"

# ----- Daily card email (Resend - free, optional) -----
# From https://resend.com (free: 100/day, 3,000/mo). Leave blank to disable emails.
RESEND_API_KEY=""
# Must use a domain you've verified in Resend, e.g. "Prayer Helper <noreply@your-domain.com>"
RESEND_FROM="Prayer Helper <noreply@your-domain.com>"
# Your site URL, used for the button in the email
NEXT_PUBLIC_SITE_URL="https://your-site.example.com"

# ----- Help / tutorial pages (optional) -----
# Unlisted guide pages at /help/<slug>. Pick unguessable slugs; leave blank to disable.
HELP_MEMBER_SLUG=""
HELP_MEMBER_VIDEO=""
HELP_ADMIN_SLUG=""
HELP_ADMIN_VIDEO=""
